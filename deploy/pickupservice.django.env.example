# Скопируйте на сервер, например: /etc/default/pickupservice.django.env
# и укажите путь в systemd Unit (EnvironmentFile=)

DJANGO_SECRET_KEY=сгенерируйте-длинную-случайную-строку
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=pickupservice.moscow,www.pickupservice.moscow,72.56.7.171
DJANGO_BEHIND_PROXY=true

CSRF_TRUSTED_ORIGINS=https://pickupservice.moscow,https://www.pickupservice.moscow

# CORS для фронта на том же домене не обязателен; при отдельном поддомене API:
# CORS_ALLOWED_ORIGINS=https://pickupservice.moscow

BOOKING_TO_EMAIL=ваша-почта@example.com
DEFAULT_FROM_EMAIL=noreply@pickupservice.moscow

# SMTP (если пусто — письма только в лог, не для продакшена)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1

# Telegram bot (уведомления о заявках)
# ВАЖНО: токен не храните в репозитории, только на сервере в этом env-файле.
TELEGRAM_BOT_TOKEN=
# Разрешённые отправители команд (user_id) и чаты (chat_id). Списки через запятую.
TELEGRAM_WHITELIST_USER_IDS=760723570
TELEGRAM_WHITELIST_CHAT_IDS=
# Куда слать авто-уведомления о новых заявках (если пусто — будет фолбэк на whitelist).
TELEGRAM_NOTIFY_CHAT_IDS=760723570

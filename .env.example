# Локальная разработка
VITE_SITE_URL=http://localhost:5173
VITE_BACKEND_ORIGIN=http://localhost:8000

# Продакшен (перед npm run build задать в .env или CI):
# VITE_SITE_URL=https://pickupservice.moscow
# VITE_BACKEND_ORIGIN=https://pickupservice.moscow

# Фронт: укажите URL Django API (на проде — тот же домен, если nginx отдаёт SPA и проксирует /api/).

# Бэкенд (Django) — задаются в окружении сервера, не в Vite:
# BOOKING_TO_EMAIL=office@example.com
# CORS_ALLOWED_ORIGINS=https://pickupservicetest.netlify.app
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@example.com
